def render_header(r: Report):
    print(f"\n{C.BOLD}{C.CYAN}══════════════════════════════════════════{C.RESET}")
    print(f"{C.BOLD}{C.CYAN}  rh-analyze — Análisis de reporte{C.RESET}")
    print(f"{C.BOLD}{C.CYAN}══════════════════════════════════════════{C.RESET}\n")
    print(f"  Host       : {r.hostname}")
    print(f"  OS         : {r.os}")
    print(f"  Kernel     : {r.kernel}")
    print(f"  Usuario    : {r.user}")
    print(f"  Auditado   : {r.timestamp}")
    schema_label = (f"{C.GREEN}v{r.schema_version} (estructurado){C.RESET}"
                    if r.is_v2()
                    else f"{C.YELLOW}v{r.schema_version} (legacy){C.RESET}")
