# ─── Modelo de datos ──────────────────────────────────────────────────────────
@dataclass
class Finding:
    """Un hallazgo individual extraído del reporte.

    En schema v2 incluye:
      - type: discriminador estructural ('suid_dangerous', 'sudo_rule', ...)
      - data: dict con campos parseados (binary, path, owner, nopasswd, etc.)

    En schema v1 (legacy):
      - type='legacy' y data={}; el matching se hace por regex sobre .text
    """
    severity: str           # 'critical' | 'warning' | 'info'
    module: str
    text: str               # Mensaje humano (siempre presente)
    type: str = 'legacy'    # Tipo estructural del finding
    data: dict = field(default_factory=dict)

    def matches(self, *patterns: str) -> bool:
        """Devuelve True si el texto del hallazgo coincide con cualquier patrón."""
        return any(re.search(p, self.text, re.IGNORECASE) for p in patterns)


@dataclass
class Report:
    """Reporte completo parseado.

    Soporta tanto schema v1 (solo arrays critical/warnings/info de strings)
    como schema v2 (array 'findings' con objetos {type, severity, message, data}).
    """
    hostname: str
    kernel: str
    os: str
    user: str
    timestamp: str
    schema_version: str = '1'
    findings: list[Finding] = field(default_factory=list)
    raw: dict = field(default_factory=dict)

    @classmethod
    def from_file(cls, path: Path) -> 'Report':
        with path.open(encoding='utf-8') as f:
            data = json.load(f)
        report = data.get('report', data)
        target = report.get('target', {})

        # Detectar schema: v2 si hay 'schema_version' o el campo 'findings' a
        # nivel report o dentro de algún module.
        schema = str(report.get('schema_version', '1'))

        findings: list[Finding] = []

        # ─── Path A: schema v2 — leer findings estructurados ──────────────
        # Preferimos el array global 'findings' del report; si no existe,
        # los recolectamos de cada module.findings.
        structured_seen = False

        if isinstance(report.get('findings'), list):
            structured_seen = True
            for f in report['findings']:
                findings.append(_finding_from_dict(f, module='?'))

        if not structured_seen:
            for module in report.get('modules', []):
                if isinstance(module.get('findings'), list):
                    structured_seen = True
                    mname = module.get('module', '?')
                    for f in module['findings']:
                        findings.append(_finding_from_dict(f, module=mname))

        if structured_seen:
            schema = '2'

        # ─── Path B: schema v1 (fallback, también si v2 está incompleto) ──
        # Si no hubo findings estructurados, parseamos los strings del módulo.
        # Si hubo, igual los conservamos en .raw para inspección, pero NO los
        # duplicamos — el v2 ya los cubre con su .text.
        if not structured_seen:
            for module in report.get('modules', []):
                mname = module.get('module', '?')
                for sev in ('critical', 'warnings', 'info'):
                    for text in module.get(sev, []):
                        findings.append(Finding(
                            severity=sev.rstrip('s'),
                            module=mname,
                            text=text,
                            type='legacy',
                            data={},
                        ))

        return cls(
            hostname=target.get('hostname', '?'),
            kernel=target.get('kernel', '?'),
            os=target.get('os', '?'),
            user=target.get('user', '?'),
            timestamp=report.get('timestamp', '?'),
            schema_version=schema,
            findings=findings,
            raw=report,
        )

    def critical(self) -> list[Finding]:
        return [f for f in self.findings if f.severity == 'critical']

    def warnings(self) -> list[Finding]:
        return [f for f in self.findings if f.severity == 'warning']

    def find(self, *patterns: str) -> list[Finding]:
        """Devuelve todos los findings que coincidan con cualquier patrón en .text."""
        return [f for f in self.findings if f.matches(*patterns)]

    def has(self, *patterns: str) -> bool:
        return bool(self.find(*patterns))

    # ─── API estructurada (schema v2) ────────────────────────────────────
    def find_by_type(self, *types: str) -> list[Finding]:
        """Devuelve findings cuyo .type coincide con alguno de los dados.

        Si el reporte es v1 (legacy), esto siempre devuelve []. Para esos
        casos seguir usando .find() con regex.
        """
        return [f for f in self.findings if f.type in types]

    def has_type(self, *types: str) -> bool:
        return bool(self.find_by_type(*types))

    def is_v2(self) -> bool:
        """¿El reporte usa schema estructurado v2?"""
        return self.schema_version == '2' or any(
            f.type != 'legacy' for f in self.findings
        )


def _finding_from_dict(d: dict, module: str = '?') -> Finding:
    """Construye un Finding desde un objeto del array 'findings' (schema v2)."""
    sev = d.get('severity', 'info')
    # Normalizar variantes ('warnings' -> 'warning')
    if sev.endswith('s') and sev != 'critical':
        sev = sev.rstrip('s')
    return Finding(
        severity=sev,
        module=module,
        text=d.get('message', ''),
        type=d.get('type', 'unknown'),
        data=d.get('data', {}) or {},
    )


# ─── Comparador de versiones ──────────────────────────────────────────────────
def parse_version(v: str) -> tuple:
    """Convierte '1.8.31p2' en (1, 8, 31) — ignora sufijos no numéricos."""
    m = re.match(r'(\d+(?:\.\d+)*)', v)
    if not m:
        return (0,)
    return tuple(int(x) for x in m.group(1).split('.'))


def vlt(a: str, b: str) -> bool:
    """¿a < b? con padding de zeros."""
    pa, pb = parse_version(a), parse_version(b)
    n = max(len(pa), len(pb))
    pa = pa + (0,) * (n - len(pa))
    pb = pb + (0,) * (n - len(pb))
    return pa < pb


def vge(a: str, b: str) -> bool:
    return not vlt(a, b)


# ─── Base de exploits ─────────────────────────────────────────────────────────
@dataclass
class Exploit:
    cve: str
    name: str
    severity: str           # 'critical' | 'high' | 'medium'
    description: str
    poc_url: str
    # Función predicado: recibe Report y devuelve True si aplica
    applies: callable = None
    requires: str = ''      # Texto explicativo de pre-requisitos
    confidence: str = 'high'  # 'high' | 'medium' | 'low'
    confidence_note: str = ''  # Por qué la confianza es la que es

EXPLOITS: list[Exploit] = []


def exploit(cve, name, severity, description, poc_url, requires='',
            confidence='high', confidence_note=''):
    """Decorador para registrar un exploit en la base."""
    def decorator(fn):
        EXPLOITS.append(Exploit(
            cve=cve, name=name, severity=severity,
            description=description, poc_url=poc_url,
            applies=fn, requires=requires,
            confidence=confidence, confidence_note=confidence_note,
        ))
        return fn
    return decorator


# ─── Helpers para obtener versiones del reporte ──────────────────────────────
# Estos helpers prefieren los findings estructurados (schema v2). Si el reporte
# es v1 (legacy), caen a regex sobre los strings. Devuelven '' cuando no
# pueden extraer la versión.

def _get_kernel_version(r: Report) -> str:
    """Devuelve la versión limpia del kernel (ej. '5.15.0') o ''."""
    if r.is_v2():
        f = r.find_by_type('kernel_version')
        if f:
            v = f[0].data.get('version', '')
            if v:
                return v
    # Fallback: parsear r.kernel directamente (formato 'X.Y.Z[-suffix]')
    m = re.match(r'(\d+\.\d+(?:\.\d+)?)', r.kernel or '')
    return m.group(1) if m else ''


def _get_glibc_version(r: Report) -> str:
    """Devuelve la versión de glibc (ej. '2.35') o ''."""
    if r.is_v2():
        f = r.find_by_type('glibc_version')
        if f:
            return f[0].data.get('version', '')
    # Fallback v1: regex sobre cualquier finding
    for f in r.find(r'glibc[:\s]+(\d+\.\d+)'):
        m = re.search(r'glibc[:\s]+(\d+\.\d+(?:\.\d+)?)', f.text, re.IGNORECASE)
        if m:
            return m.group(1)
    return ''


def _get_sudo_version(r: Report) -> str:
    """Devuelve la versión de sudo (ej. '1.9.5p2') o ''."""
    if r.is_v2():
        f = r.find_by_type('sudo_version')
        if f:
            return f[0].data.get('version', '')
    # Fallback v1: regex sobre cualquier finding cuyo texto mencione sudo
    # Acepta variantes: "sudo: 1.8.31p2", "sudo versión: 1.8.31p2", "Sudo 1.9.5"
    for f in r.findings:
        if 'sudo' in f.text.lower():
            m = re.search(r'(\d+\.\d+\.\d+(?:p\d+)?)', f.text)
            if m:
                return m.group(1)
    return ''


def _get_pkexec_version(r: Report) -> str:
    """Devuelve la versión de pkexec o ''."""
    if r.is_v2():
        f = r.find_by_type('pkexec_version')
        if f:
            return f[0].data.get('version', '')
    return ''


def _kernel_userns_unrestricted(r: Report) -> bool:
    """¿unprivileged_userns_clone=1? Eleva la viabilidad de varios exploits."""
    if r.is_v2():
        for f in r.find_by_type('kernel_protection'):
            if f.data.get('name') == 'unprivileged_userns_clone':
                return f.data.get('value') == '1'
    return False


