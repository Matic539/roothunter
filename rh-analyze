        rel, stl, spd = 5, 5, 5
        score, tier = gtfobins.score_technique(rel, stl, spd)
        # Lista los primeros 3 PIDs únicos
        pids_seen = []
        for ef in env_secrets:
            p = ef.data.get('pid', '?')
            if p not in pids_seen:
