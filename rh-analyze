        })

    for f in r.find_by_type('cron_writable_script')[:3]:
        script = f.data.get('script', '?')
        cron_owner = f.data.get('cron_owner', '?')
        cron_source = f.data.get('cron_source', '?')
        # Cron: confiable pero requiere espera (hasta 1h) y deja artefactos
        rel, stl, spd = 4, 3, 2
        score, tier = gtfobins.score_technique(rel, stl, spd)
        out.append({
            'title':         f"Script cron escribible: {script}",
