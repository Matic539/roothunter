# ─── Attack paths ─────────────────────────────────────────────────────────────
@dataclass
class AttackPath:
    name: str
    severity: str
    steps: list[str]
    impact: str             # Descripción del resultado final (ej: 'shell como root')


def find_attack_paths(r: Report) -> list[AttackPath]:
    """Encadena hallazgos para construir rutas de escalada."""
    paths = []

    # Patrón: cron escribible → ejecución como root
    cron_writable = r.find(r'cron.*escrib', r'cron.*writable', r'Script cron ESCRIBIBLE')
    if cron_writable:
        paths.append(AttackPath(
            name='Escalada vía cron escribible',
            severity='critical',
            steps=[
                f"Identificado: {cron_writable[0].text}",
                "Modificar el script con un payload (reverse shell o copia de bash con SUID)",
                "Esperar próxima ejecución del cron (típicamente ≤ 1 hora)",
                "Obtener ejecución como root",
            ],
            impact='Shell como root tras la próxima ejecución del cron',
        ))

    # Patrón: SUID peligroso explotable
    suid_dangerous = r.find(r'SUID peligroso')
    for finding in suid_dangerous[:3]:
        m = re.search(r'/[\w/]+/(\w+)', finding.text)
        if m:
            binary = m.group(1)
            paths.append(AttackPath(
                name=f'Escalada vía SUID en {binary}',
                severity='critical',
                steps=[
                    f"Binario SUID detectado: {finding.text}",
                    f"Consultar técnica específica en GTFOBins",
                    f"Ejecutar payload de escalada documentado",
                ],
                impact=f'Ejecución directa como root vía {binary}',
            ))

    # Patrón: NOPASSWD sudo
    if r.has(r'NOPASSWD', r'sudo SIN contrase'):
        paths.append(AttackPath(
            name='Escalada vía sudo NOPASSWD',
            severity='critical',
            steps=[
                "Sudo configurado para ejecutar comandos sin contraseña",
                "Revisar sudo -l para identificar comandos permitidos",
                "Si el comando está en GTFOBins, usar la técnica documentada",
                "Caso típico: sudo /usr/bin/find . -exec /bin/sh \\; -quit",
            ],
            impact='Shell como root inmediato',
        ))

    # Patrón: PATH escribible + cron como root
    path_writable = r.find(r'ESCRIBIBLE en PATH', r'PATH hijacking')
    if path_writable and (cron_writable or r.has(r'cron')):
        paths.append(AttackPath(
            name='Escalada vía PATH hijacking + cron',
            severity='critical',
            steps=[
                f"Directorio escribible en PATH: {path_writable[0].text}",
                "Identificar comandos sin ruta absoluta en scripts cron de root",
                "Crear un binario malicioso con ese nombre en el directorio escribible",
                "Esperar ejecución del cron",
            ],
            impact='Ejecución como root cuando cron invoque el comando',
        ))

    # Patrón: kernel vulnerable + sin user namespaces restringidos
    if r.has(r'CVE-2022-0847', r'Dirty Pipe', r'CVE-2023-4911', r'Looney'):
        paths.append(AttackPath(
            name='Escalada vía exploit de kernel/glibc',
            severity='critical',
            steps=[
                "Versión vulnerable detectada (ver sección de exploits)",
                "Compilar y ejecutar el PoC público en el host",
                "Obtener shell como root",
            ],
            impact='Ejecución arbitraria con privilegios de kernel',
        ))

    # Patrón: clave SSH privada legible
    ssh_keys = r.find(r'Clave SSH privada legible')
    if ssh_keys:
        paths.append(AttackPath(
            name='Movimiento lateral vía clave SSH expuesta',
            severity='high',
            steps=[
                f"Clave privada legible: {ssh_keys[0].text}",
                "Determinar qué usuarios/hosts confían en esta clave",
                "Usar la clave para autenticarse en otros sistemas",
            ],
            impact='Acceso a sistemas que confíen en esta clave',
        ))

    # Patrón: token K8s accesible
    if r.has(r'Kubernetes ServiceAccount'):
        paths.append(AttackPath(
            name='Movimiento lateral en cluster Kubernetes',
            severity='high',
            steps=[
                "Token de ServiceAccount accesible",
                "Usar kubectl con el token para enumerar permisos",
                "Pivote a otros pods/secrets según permisos del SA",
            ],
            impact='Posible takeover del cluster según privilegios del SA',
        ))

    # Patrón: credenciales cloud accesibles vía IMDS
    if r.has(r'Credenciales AWS IAM accesibles', r'Token Managed Identity', r'Token de servicio GCP'):
        paths.append(AttackPath(
            name='Movimiento lateral en cuenta cloud',
            severity='high',
            steps=[
                "Credenciales temporales obtenibles vía IMDS",
                "Configurar AWS/GCP/Azure CLI con las credenciales",
                "Enumerar permisos del rol y pivotar a recursos accesibles",
            ],
            impact='Acceso a recursos cloud según permisos del rol',
        ))

    # Patrón: secretos en /proc/<pid>/environ — credenciales gratis
    if r.has_type('process_env_secret'):
        n = len(r.find_by_type('process_env_secret'))
        paths.append(AttackPath(
            name='Robo de credenciales desde /proc/<pid>/environ',
            severity='critical',
            steps=[
                f"{n} variables sensibles legibles en environ de procesos ajenos",
                "Extraer credenciales con: tr '\\0' '\\n' < /proc/<pid>/environ | grep -i password",
                "Usar las credenciales para acceso lateral (DB, API, cloud, etc.)",
            ],
            impact='Movimiento lateral con credenciales de servicios corriendo en el host',
        ))

    # Patrón: binario root escribible — escalada al reinicio
    if r.has_type('process_root_writable_binary'):
        bin_path = r.find_by_type('process_root_writable_binary')[0].data.get('path', '?')
        paths.append(AttackPath(
            name='Escalada vía binario de proceso root escribible',
            severity='critical',
            steps=[
                f"Binario detectado: {bin_path}",
                "Reemplazar con un wrapper que copia bash con SUID antes de exec original",
                "Esperar reinicio del proceso (servicio, host, o forzar via failure conditions)",
                "Tras restart: /tmp/.b -p da shell como root",
            ],
            impact='Shell como root tras el próximo reinicio del proceso',
        ))

    # Patrón: profile.d / shell_rc escribible — escalada al login
    if r.has_type('profile_d_writable', 'shell_rc_writable'):
        paths.append(AttackPath(
            name='Escalada vía hijack de config de shell',
            severity='high',
            steps=[
                "Configs de shell escribibles detectadas (profile.d o .bashrc/.zshrc ajenos)",
                "Inyectar payload que cree SUID-bash o reverse shell",
                "Esperar a que el usuario afectado inicie una sesión interactiva",
                "Verificar quién puede hacer login y con qué frecuencia: who, last",
            ],
            impact='Escalada cuando el usuario objetivo inicia sesión',
        ))

    # Patrón: socket unix escribible — depende del daemon
    if r.has_type('unix_socket_writable'):
        socks = r.find_by_type('unix_socket_writable')
        sock_path = socks[0].data.get('path', '?')
        paths.append(AttackPath(
            name='Abuso de socket unix escribible',
            severity='high',
            steps=[
                f"Socket detectado: {sock_path}",
                "Identificar el daemon que lo expone (lsof, ss, fuser)",
                "Para Redis: CONFIG SET dir + SET escribe archivos arbitrarios",
                "Para Docker/runtime: spawn de container privilegiado",
                "Para PostgreSQL/MySQL: queries con permisos del daemon",
            ],
            impact='RCE o lectura/escritura privilegiada según daemon',
        ))

    return paths


# ─── Scoring ──────────────────────────────────────────────────────────────────
def calculate_score(r: Report) -> tuple[int, dict]:
    """Devuelve (score 0-100, breakdown).

    Los findings de tipo 'suid_dangerous' que están en la whitelist de la
    distro se descuentan del bucket 'críticos' — son SUID legítimos que el
    sistema necesita y no representan un vector de escalada por sí mismos.
    """
    breakdown = {}

    # Críticos: contar todos los críticos pero descontar los SUID whitelisted
    all_crit = r.critical()
    whitelisted = 0
    for f in all_crit:
        ok, _ = is_suid_legitimate(f, r)
        if ok:
            whitelisted += 1
    n_crit_effective = len(all_crit) - whitelisted
    breakdown['críticos'] = min(n_crit_effective * 10, 60)
    if whitelisted > 0:
        breakdown['_suid_whitelisted'] = whitelisted

    # Advertencias pesan menos
    n_warn = len(r.warnings())
    breakdown['advertencias'] = min(n_warn * 2, 20)

    # Bonus contextual: ciertos hallazgos elevan el riesgo desproporcionadamente
    bonus = 0
    bonus_reasons = []

    if r.has(r'docker.sock.*escribible', r'grupo docker'):
        bonus += 10
        bonus_reasons.append('acceso a Docker')
    if r.has(r'NOPASSWD'):
        bonus += 8
        bonus_reasons.append('sudo NOPASSWD')
    if r.has(r'/etc/shadow LEGIBLE', r'shadow.*legible'):
        bonus += 8
        bonus_reasons.append('shadow legible')
    if r.has(r'IMDSv1 accesible SIN token'):
        bonus += 6
        bonus_reasons.append('IMDS sin token')
    if r.has(r'Credenciales AWS IAM accesibles'):
        bonus += 8
        bonus_reasons.append('credenciales cloud')
    if r.has(r'pam_permit sufficient'):
        bonus += 10
        bonus_reasons.append('PAM backdoor')
    # Nuevos bonus para módulo processes
    if r.has_type('process_env_secret', 'process_cmdline_secret'):
        bonus += 8
        bonus_reasons.append('secretos en /proc')
    if r.has_type('process_root_writable_binary'):
        bonus += 8
        bonus_reasons.append('binario root escribible')
    if r.has_type('profile_d_writable'):
        bonus += 6
        bonus_reasons.append('profile.d escribible')
    if r.has_type('unix_socket_writable'):
        bonus += 5
        bonus_reasons.append('socket unix escribible')

    breakdown['contexto'] = min(bonus, 20)
    if bonus_reasons:
        breakdown['_bonus_por'] = ', '.join(bonus_reasons)

    score = sum(v for k, v in breakdown.items() if not k.startswith('_'))
    return min(score, 100), breakdown


def risk_level(score: int) -> tuple[str, str]:
    """Devuelve (nivel, color)."""
    if score >= 70:
        return 'CRÍTICO', C.RED
    if score >= 40:
        return 'ALTO', C.YELLOW
    if score >= 15:
        return 'MEDIO', C.CYAN
    return 'BAJO', C.GREEN


