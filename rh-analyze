                           '# Casos típicos:\n'
                           '#   Redis: nc -U <sock>; CONFIG SET dir /etc; CONFIG SET dbfilename cron.d/r; SET x ...\n'
                           '#   Docker: similar a docker.sock — ver módulo containers\n'
