    # ─── 7) Procesos: passwords en /proc/*/cmdline ───────────────────────
    cmd_secrets = r.find_by_type('process_cmdline_secret')
    if cmd_secrets:
        rel, stl, spd = 5, 5, 5
        score, tier = gtfobins.score_technique(rel, stl, spd)
        first_pid = cmd_secrets[0].data.get('pid', '?')
