# ─── Modo diff ────────────────────────────────────────────────────────────────
def render_diff(old: Report, new: Report):
    print(f"\n{C.BOLD}── Diff entre auditorías ──{C.RESET}")
    print(f"  Antes : {old.timestamp}")
    print(f"  Ahora : {new.timestamp}\n")

    old_set = {(f.severity, f.text) for f in old.findings}
    new_set = {(f.severity, f.text) for f in new.findings}

    added = new_set - old_set
    removed = old_set - new_set

    added_crit = [t for s, t in added if s == 'critical']
    removed_crit = [t for s, t in removed if s == 'critical']

    if added_crit:
        print(f"  {C.RED}{C.BOLD}Nuevos hallazgos críticos: {len(added_crit)}{C.RESET}")
        for t in added_crit[:10]:
            print(f"    {C.RED}+ {t}{C.RESET}")
        if len(added_crit) > 10:
            print(f"    {C.DIM}... y {len(added_crit) - 10} más{C.RESET}")
        print()

    if removed_crit:
        print(f"  {C.GREEN}{C.BOLD}Críticos remediados: {len(removed_crit)}{C.RESET}")
        for t in removed_crit[:10]:
            print(f"    {C.GREEN}- {t}{C.RESET}")
        print()

    if not added_crit and not removed_crit:
        print(f"  {C.CYAN}Sin cambios en hallazgos críticos.{C.RESET}\n")

    # Cambio en score
    score_old, _ = calculate_score(old)
    score_new, _ = calculate_score(new)
    delta = score_new - score_old
    arrow = '↑' if delta > 0 else ('↓' if delta < 0 else '=')
    color = C.RED if delta > 0 else (C.GREEN if delta < 0 else C.DIM)
    print(f"  Score: {score_old} → {score_new} {color}{arrow} {abs(delta):+d}{C.RESET}\n")


# ─── Modo batch ───────────────────────────────────────────────────────────────
def render_batch(reports: list[Report]):
    print(f"\n{C.BOLD}── Análisis batch — {len(reports)} hosts ──{C.RESET}\n")
    rows = []
    for r in reports:
        score, _ = calculate_score(r)
        level, _ = risk_level(score)
        n_exp = sum(1 for e in EXPLOITS if e.applies(r))
        n_paths = len(find_attack_paths(r))
        rows.append((score, level, r.hostname, r.kernel, n_exp, n_paths))

    rows.sort(key=lambda x: -x[0])  # Ordenar por score descendente

    print(f"  {'Score':>5}  {'Nivel':<10} {'Hostname':<25} {'Kernel':<20} {'Expl':>4} {'Paths':>5}")
    print(f"  {'-' * 5}  {'-' * 10} {'-' * 25} {'-' * 20} {'-' * 4} {'-' * 5}")
    for score, level, host, kernel, n_exp, n_paths in rows:
        _, color = risk_level(score)
        print(f"  {color}{score:>5}{C.RESET}  {level:<10} "
              f"{host[:25]:<25} {kernel[:20]:<20} {n_exp:>4} {n_paths:>5}")
    print()


# ─── Exportar Markdown ────────────────────────────────────────────────────────
def export_markdown(r: Report, path: Path):
    """Genera un reporte Markdown limpio para compartir."""
    score, breakdown = calculate_score(r)
    level, _ = risk_level(score)
    applicable = [e for e in EXPLOITS if e.applies(r)]
    paths = find_attack_paths(r)

    md = []
    md.append(f"# Análisis de seguridad — {r.hostname}\n")
    md.append(f"**Generado por rh-analyze** sobre reporte de RootHunter\n")
    md.append(f"## Resumen\n")
    md.append(f"| Campo | Valor |")
    md.append(f"|-------|-------|")
    md.append(f"| Host | `{r.hostname}` |")
    md.append(f"| OS | {r.os} |")
    md.append(f"| Kernel | `{r.kernel}` |")
    md.append(f"| Auditado | {r.timestamp} |")
    md.append(f"| Score de riesgo | **{score}/100 [{level}]** |")
    md.append(f"| Críticos | {len(r.critical())} |")
    md.append(f"| Advertencias | {len(r.warnings())} |\n")

    if applicable:
        md.append(f"## Exploits sugeridos\n")
        for e in applicable:
            md.append(f"### {e.name}")
            md.append(f"- **Severidad:** {e.severity}")
            md.append(f"- **Confianza:** {e.confidence}")
            md.append(f"- **CVE/Ref:** {e.cve}")
            md.append(f"- **Descripción:** {e.description}")
            if e.requires:
                md.append(f"- **Requiere:** {e.requires}")
            if e.confidence_note:
                md.append(f"- **Nota sobre confianza:** {e.confidence_note}")
            md.append(f"- **PoC:** [{e.poc_url}]({e.poc_url})\n")

    if paths:
        md.append(f"## Attack paths\n")
        for i, p in enumerate(paths, 1):
            md.append(f"### Path #{i}: {p.name}")
            md.append(f"**Severidad:** {p.severity}\n")
            for j, step in enumerate(p.steps, 1):
                md.append(f"{j}. {step}")
            md.append(f"\n> **Impacto:** {p.impact}\n")

    md.append(f"## Recomendaciones\n")
    if score >= 70:
        md.append("- **Acción inmediata requerida.** Múltiples vectores explotables detectados.")
    elif score >= 40:
        md.append("- Priorizar remediación de hallazgos críticos en las próximas 24-48h.")
    else:
        md.append("- Endurecer configuración según advertencias detectadas.")
    md.append("- Re-auditar tras aplicar correcciones con `roothunter.sh -j` y comparar con `rh-analyze --diff`.\n")

    path.write_text('\n'.join(md), encoding='utf-8')
    print(f"  {C.GREEN}Reporte Markdown guardado en: {path}{C.RESET}")


# ─── Main ─────────────────────────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        description='Analizador de reportes RootHunter',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Ejemplos:
  %(prog)s reporte.json
  %(prog)s reporte.json --score
  %(prog)s reporte.json --exploits --paths
  %(prog)s reporte.json --commands           # comandos exactos sugeridos
  %(prog)s --diff antes.json despues.json
  %(prog)s --batch host1.json host2.json host3.json
  %(prog)s reporte.json -o analisis.md
  %(prog)s --list-techniques                 # ver coverage de gtfobins.py
        """,
    )
    parser.add_argument('reports', nargs='*', type=Path,
                        help='Reportes JSON de RootHunter')
    parser.add_argument('--score', action='store_true', help='Solo mostrar score')
    parser.add_argument('--exploits', action='store_true', help='Solo exploits sugeridos')
    parser.add_argument('--paths', action='store_true', help='Solo attack paths')
    parser.add_argument('--commands', action='store_true',
                        help='Solo comandos accionables (requiere reporte v2)')
    parser.add_argument('--playbook', action='store_true',
                        help='Modo copy-paste: solo comandos en orden de prioridad, '
                             'sin colores ni metadata. Ideal para guardar como .txt.')
    parser.add_argument('--confirm', action='store_true',
                        help='Ejecutar dry_run de cada técnica accionable EN ESTE HOST '
                             'para confirmar que el exploit funciona. Solo usar si estás '
                             'autorizado en este sistema. Comandos no-destructivos por diseño.')
    parser.add_argument('--diff', nargs=2, type=Path, metavar=('OLD', 'NEW'),
                        help='Comparar dos reportes')
    parser.add_argument('--batch', action='store_true',
                        help='Procesar múltiples reportes y priorizar')
    parser.add_argument('-o', '--output', type=Path,
                        help='Exportar análisis a Markdown')
    parser.add_argument('--no-color', action='store_true', help='Desactivar colores ANSI')
    parser.add_argument('--list-techniques', action='store_true',
                        help='Listar coverage de gtfobins.py y salir')

    args = parser.parse_args()

    if args.no_color or not sys.stdout.isatty():
        C.disable()

    # Modo --list-techniques: mostrar coverage de la base local y salir
    if args.list_techniques:
        if gtfobins is None:
            print(f"{C.RED}gtfobins.py no se pudo cargar{C.RESET}")
            sys.exit(1)
        cov = gtfobins.coverage_summary()
        print(f"\n{C.BOLD}Cobertura de gtfobins.py{C.RESET}\n")
        print(f"  Binarios SUID documentados   : {cov['suid_count']}")
        print(f"  Binarios sudo documentados   : {cov['sudo_count']}")
        print(f"  Capabilities con explotación : {cov['capabilities_count']}")
        print(f"  Técnicas por capability      : {cov['capability_techniques_count']}")
        print(f"\n  {C.DIM}SUID:    {', '.join(gtfobins.all_suid_binaries())}{C.RESET}")
        print(f"\n  {C.DIM}Sudo:    {', '.join(gtfobins.all_sudo_binaries())}{C.RESET}")
        print(f"\n  {C.DIM}Caps:    {', '.join(gtfobins.all_capabilities())}{C.RESET}\n")

        if suid_whitelist is not None:
            wl = suid_whitelist.whitelist_summary()
            print(f"{C.BOLD}Whitelist de SUID legítimos (suid_whitelist.py){C.RESET}\n")
            print(f"  Comunes a todas las distros : {wl['common_count']}")
            print(f"  Específicos Debian/Ubuntu   : {wl['debian_count']}")
            print(f"  Específicos RHEL/Fedora     : {wl['rhel_count']}")
            print(f"  Específicos Arch            : {wl['arch_count']}")
            print(f"  Específicos Alpine          : {wl['alpine_count']}")
            print(f"  Total paths únicos          : {wl['total_unique_paths']}\n")
        return

    # Modo diff
    if args.diff:
        old, new = Report.from_file(args.diff[0]), Report.from_file(args.diff[1])
        render_diff(old, new)
        return

    # Sin reportes
    if not args.reports:
        parser.print_help()
        sys.exit(1)

    # Modo batch
    if args.batch or len(args.reports) > 1:
        reports = [Report.from_file(p) for p in args.reports]
        render_batch(reports)
        return

    # Análisis simple
    r = Report.from_file(args.reports[0])

    # Modo --playbook: solo comandos copy-paste, sin colores ni decoración
    if args.playbook:
        C.disable()  # forzar sin colores
        render_playbook(r)
        return

    # Modo --confirm: ejecutar dry_run en el host actual
    if args.confirm:
        render_header(r)
        render_confirm(r)
        return

    if args.output:
        export_markdown(r, args.output)
        return

    render_header(r)

    # Si se especifican secciones, solo mostrar esas. Si no, todas.
    show_all = not (args.score or args.exploits or args.paths or args.commands)

    if show_all or args.score:
        render_score(r)
    if show_all or args.exploits:
        render_exploits(r)
    if show_all or args.commands:
        render_actionable_commands(r)
    if show_all or args.paths:
        render_attack_paths(r)
    if show_all:
        render_summary(r)


if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(130)
    except json.JSONDecodeError as e:
        print(f"{C.RED}Error: el archivo no es un JSON válido: {e}{C.RESET}", file=sys.stderr)
        sys.exit(1)
    except FileNotFoundError as e:
        print(f"{C.RED}Error: archivo no encontrado: {e.filename}{C.RESET}", file=sys.stderr)
        sys.exit(1)
