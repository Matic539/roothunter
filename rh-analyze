                'why':     'el .bashrc/.zshrc se carga al login interactivo de ese usuario',
                'success': success_msg,
                'notes':   'Si el usuario no hace login nunca, el vector no se dispara — ver `last` para estimar',
                'ref':     'https://book.hacktricks.xyz/linux-hardening/privilege-escalation#bashrc',
            },
            'extra_context': "  |  ".join(targets),
            'tier': tier, 'score': score,
            'reliability': rel, 'stealth': stl, 'speed': spd,
            'kind': 'special',
        })

    return out


def _tier_label(tier: int) -> tuple[str, str]:
    """Devuelve (etiqueta, color) para un tier."""
    if tier == 1:
        return "TIER 1 — WIN FÁCIL (intenta primero)", C.GREEN
    if tier == 2:
        return "TIER 2 — PLAN B (si tier 1 falla)", C.YELLOW
    return "TIER 3 — ÚLTIMO RECURSO (frágil o ruidoso)", C.RED


def render_actionable_commands(r: Report):
    """Para cada finding estructurado relevante, sugiere el comando exacto.

    Las técnicas se agrupan por tier (1=win fácil, 2=plan B, 3=último recurso)
    y dentro de cada tier se ordenan por score descendente. Eso replica el
    flujo mental de un pentester: empezar por lo que más probable funciona.
    Solo funciona con reportes schema v2.
    """
    print(f"{C.BOLD}── Comandos sugeridos (priorizados) ──{C.RESET}")

    if gtfobins is None:
        print(f"  {C.YELLOW}Advertencia: gtfobins.py no se pudo cargar.{C.RESET}")
        print(f"  {C.DIM}Verifica que esté en el mismo directorio que rh-analyze.{C.RESET}\n")
        return

    if not r.is_v2():
        print(f"  {C.YELLOW}El reporte es v1 (legacy) — no contiene findings estructurados.{C.RESET}")
        print(f"  {C.DIM}Re-ejecutar roothunter.sh ≥ v1.1 para obtener comandos exactos.{C.RESET}\n")
        return

    techniques = collect_techniques(r)

    # ─── SUID legítimos (whitelist) — informativo arriba ────────────────
    suid_findings = r.find_by_type('suid_dangerous')
    legitimate = []
    no_technique = []
    for f in suid_findings:
        ok, reason = is_suid_legitimate(f, r)
        if ok:
            legitimate.append((f, reason))
            continue
        bin_name = f.data.get('binary', '')
        if gtfobins.lookup_suid(bin_name) is None:
            no_technique.append(f)
    if legitimate:
        print(f"\n  {C.DIM}SUID legítimos del sistema (whitelist): {len(legitimate)}"
              f" — omitidos del análisis ofensivo{C.RESET}")
        for f, reason in legitimate[:5]:
            print(f"    {C.DIM}· {f.data.get('path', '?')}  ({reason}){C.RESET}")
        if len(legitimate) > 5:
            print(f"    {C.DIM}... y {len(legitimate) - 5} más{C.RESET}")

    # ─── Render por tier ────────────────────────────────────────────────
    if not techniques:
        print(f"\n  {C.GREEN}No se encontraron vectores con comando concreto sugerible.{C.RESET}")
        print(f"  {C.DIM}Esto NO significa que el sistema sea seguro — revisar también")
        print(f"  --paths y --exploits para vectores que no producen comando directo.{C.RESET}\n")
        # Aún así, mostrar SUID sin técnica documentada
        if no_technique:
            print(f"  {C.YELLOW}SUID sin técnica documentada en la base local "
                  f"(revisar manualmente):{C.RESET}")
            for f in no_technique:
                bn = f.data.get('binary', '?')
                print(f"    · {f.data.get('path', '?')}  "
                      f"→ https://gtfobins.github.io/gtfobins/{bn}/")
            print()
        return

    # Orden: tier asc, dentro de cada tier los verificados primero,
    # luego score desc. Esto pone al frente lo que sabemos que funciona.
    def _sort_key(t):
        v = t.get('verification', {}).get('verified', 'unknown')
        # Prioridad: verified=true > unknown > false (lo que falló al verificar
        # va al fondo porque sabemos que NO funciona)
        verified_priority = {'true': 0, 'unknown': 1, 'false': 2}.get(v, 1)
        return (t['tier'], verified_priority, -t['score'])
    techniques.sort(key=_sort_key)

    current_tier = None
    for t in techniques:
        if t['tier'] != current_tier:
            current_tier = t['tier']
            label, color = _tier_label(current_tier)
            print(f"\n  {color}{C.BOLD}▶ {label}{C.RESET}")

        # Badge de verificación: depende del estado en el finding
        v = t.get('verification', {})
        v_status = v.get('verified', 'unknown')
        v_level = v.get('verified_at_level', 'none')
        if v_status == 'true':
            badge = f"{C.GREEN}✓ VERIFICADO{C.RESET}"
            if v_level and v_level != 'none':
                badge += f" {C.DIM}({v_level}){C.RESET}"
        elif v_status == 'false':
            badge = f"{C.RED}✗ NO VIABLE{C.RESET} {C.DIM}(precondition falló){C.RESET}"
        else:
            badge = f"{C.DIM}? sin verificar{C.RESET}"

        # Línea de score visible
        score_line = (f"  reliability={t['reliability']}  "
                      f"stealth={t['stealth']}  "
                      f"speed={t['speed']}  "
                      f"→ score={t['score']}")
        print(f"\n  {C.DIM}[score {t['score']}/25]{C.RESET}  "
              f"{C.BOLD}{t['title']}{C.RESET}  {badge}")
        print(f"    {C.DIM}{score_line}{C.RESET}")
        if t['extra_context']:
            print(f"    {C.DIM}{t['extra_context']}{C.RESET}")
        # Si hay output de verify, mostrarlo (ayuda a entender por qué pasó/falló)
        v_out = v.get('verify_output', '')
        if v_out and v_status in ('true', 'false'):
            print(f"    {C.DIM}Verify output: {v_out[:80]}{C.RESET}")
        tech = t['technique']
        if tech.get('why'):
            print(f"    {C.DIM}Por qué funciona:{C.RESET} {tech['why']}")
        if tech.get('verify'):
            print(f"    {C.CYAN}Verificar:{C.RESET}  {tech['verify']}")
        if tech.get('exploit'):
            print(f"    {C.RED}Explotar:{C.RESET}   {tech['exploit']}")
        if tech.get('success'):
            print(f"    {C.GREEN}Éxito si:{C.RESET}   {tech['success']}")
        if tech.get('notes'):
            print(f"    {C.YELLOW}Notas:{C.RESET}      {tech['notes']}")
        if tech.get('ref'):
            print(f"    {C.DIM}Referencia: {tech['ref']}{C.RESET}")

    # SUID sin técnica al final
    if no_technique:
        print(f"\n  {C.YELLOW}SUID sin técnica documentada en la base local "
              f"(revisar manualmente):{C.RESET}")
        for f in no_technique:
            bn = f.data.get('binary', '?')
            print(f"    · {f.data.get('path', '?')}  "
                  f"→ https://gtfobins.github.io/gtfobins/{bn}/")

    # Cierre con resumen por tier y estado de verificación
    by_tier = {1: 0, 2: 0, 3: 0}
    by_verified = {'true': 0, 'false': 0, 'unknown': 0}
    # Solo contamos verificación en kinds que pueden ser verificados (suid/sudo/capability)
    verifiable_kinds = {'suid', 'sudo', 'capability'}
    verifiable_total = 0
    for t in techniques:
        by_tier[t['tier']] += 1
        if t.get('kind') in verifiable_kinds:
            verifiable_total += 1
            v = t.get('verification', {}).get('verified', 'unknown')
            by_verified[v] = by_verified.get(v, 0) + 1
    print(f"\n  {C.DIM}Resumen: tier 1 = {by_tier[1]}, "
          f"tier 2 = {by_tier[2]}, "
          f"tier 3 = {by_tier[3]}{C.RESET}")
    if verifiable_total > 0:
        if by_verified['true'] or by_verified['false']:
            print(f"  {C.DIM}Verificación: "
                  f"{C.GREEN}✓ {by_verified['true']} confirmados{C.RESET}{C.DIM}, "
                  f"{C.RED}✗ {by_verified['false']} no viables{C.RESET}{C.DIM}, "
                  f"? {by_verified['unknown']} sin verificar{C.RESET}")
        elif by_verified['unknown'] == verifiable_total:
            print(f"  {C.DIM}Para confirmar vectores SUID/sudo/capabilities: "
                  f"re-ejecutar roothunter.sh con -V{C.RESET}")
    print(f"  {C.YELLOW}⚠  Estos comandos son material defensivo: úsalos solo en sistemas")
    print(f"  con autorización explícita.{C.RESET}\n")


def render_confirm(r: Report):
    """Modo --confirm: ejecuta el dry_run de gtfobins.py localmente para
    cada técnica accionable, e imprime "CONFIRMADO" si el output coincide.

    REQUIERE estar ejecutándose EN EL HOST OBJETIVO. Ejecuta comandos reales
    no-destructivos del sistema. Es opt-in (nunca corre por defecto).

    Cada dry_run debe cumplir las tres reglas inviolables:
       1. NO spawnea shell interactiva
       2. NO modifica el sistema
       3. NO hace conexiones de red salientes
    Esas reglas las garantiza gtfobins.py al definir las técnicas.
    """
    import subprocess

    print(f"{C.BOLD}── Confirmación con dry_run (opt-in) ──{C.RESET}")
    print(f"  {C.YELLOW}⚠  Ejecutando comandos no-destructivos en este host{C.RESET}")
    print(f"  {C.YELLOW}⚠  Solo usar si estás autorizado en este sistema{C.RESET}\n")

    if gtfobins is None or not r.is_v2():
        print(f"  {C.RED}--confirm requiere gtfobins.py + reporte schema v2{C.RESET}")
        return

    techniques = collect_techniques(r)
    if not techniques:
        print(f"  {C.GREEN}No hay técnicas accionables que confirmar.{C.RESET}\n")
        return

    confirmed = 0
    failed = 0
    skipped = 0

    for t in techniques:
        # Solo intentamos dry_run en SUID/sudo/capability (los que vienen de gtfobins).
        # Los 'special' (Docker, K8s, IMDS) no tienen dry_run estandarizado aquí.
        if t['kind'] not in ('suid', 'sudo', 'capability'):
            continue

        # Si el verifier de roothunter ya marcó verified=false, NO ejecutamos
        # el dry_run — la precondition no se cumple y sería desperdicio
        v = t.get('verification', {})
        if v.get('verified') == 'false':
            print(f"  {C.DIM}↳ {t['title']:40} - skip (precondition falló){C.RESET}")
            skipped += 1
            continue

        dry = gtfobins.get_dry_run(t['technique'])
        if dry is None:
            print(f"  {C.DIM}↳ {t['title']:40} - skip (sin dry_run seguro){C.RESET}")
            skipped += 1
            continue

        cmd, expected = dry

        # Ejecutar con timeout. Capturamos stdout+stderr.
        try:
            proc = subprocess.run(
                ['bash', '-c', cmd],
                capture_output=True, text=True, timeout=10,
            )
            output = (proc.stdout + proc.stderr).strip()[:200]
        except subprocess.TimeoutExpired:
            output = '<timeout>'
        except Exception as e:
            output = f'<error: {e}>'

        # Heurística simple para ver si el output coincide con expected.
        # Buscamos marcadores DRYRUN_ o euid=0 o uid=0 en el output.
        ok = False
        markers = ['DRYRUN_EUID= 0', 'DRYRUN_UID= 0', 'uid=0(root)',
                   'DRYRUN_EUID=0', 'DRYRUN_UID=0',
                   'DRYRUN_SHADOW=']
        if any(m in output for m in markers):
            ok = True

        if ok:
            print(f"  {C.GREEN}✓ CONFIRMADO{C.RESET}  {t['title']:40}")
            print(f"    {C.DIM}output: {output[:100]}{C.RESET}")
            confirmed += 1
        else:
            print(f"  {C.RED}✗ NO CONFIRMADO{C.RESET}  {t['title']:40}")
            print(f"    {C.DIM}esperado: {expected[:80]}{C.RESET}")
            print(f"    {C.DIM}obtenido: {output[:80] if output else '(sin output)'}{C.RESET}")
            failed += 1

    print(f"\n  {C.BOLD}Confirmación completada:{C.RESET}")
    print(f"    {C.GREEN}✓ {confirmed} confirmados{C.RESET}")
    print(f"    {C.RED}✗ {failed} no confirmados{C.RESET}")
    print(f"    {C.DIM}- {skipped} skipped (sin dry_run seguro o ya descartados){C.RESET}")
    print()


def render_playbook(r: Report):
    """Modo copy-paste: solo comandos en orden de prioridad, sin metadata.

    Ideal para tener notas en .txt. Cada técnica imprime el comando de
    verify y el de exploit, agrupados por tier.
    """
    if gtfobins is None or not r.is_v2():
        print("# Playbook no disponible: requiere reporte schema v2 + gtfobins.py")
        return

    techniques = collect_techniques(r)
    if not techniques:
        print("# Sin técnicas accionables detectadas.")
        return

    techniques.sort(key=lambda t: (t['tier'], -t['score']))

    print(f"# Playbook generado por rh-analyze — {r.hostname}")
    print(f"# Auditado: {r.timestamp}")
    print(f"# {len(techniques)} técnicas en orden de prioridad\n")

    current_tier = None
    for t in techniques:
        if t['tier'] != current_tier:
            current_tier = t['tier']
            label, _ = _tier_label(current_tier)
            print(f"\n# ─── {label} ───")
        print(f"\n# {t['title']}  [score {t['score']}/25]")
        if t['extra_context']:
            print(f"# {t['extra_context']}")
        tech = t['technique']
        if tech.get('verify'):
            print(f"#   verify:")
            print(f"{tech['verify']}")
        if tech.get('exploit'):
            print(f"#   exploit:")
            print(f"{tech['exploit']}")


