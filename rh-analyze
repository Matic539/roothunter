#!/usr/bin/env python3
# =============================================================================
#  rh-analyze — Analizador de reportes RootHunter v1.2
#  Lee reportes JSON generados por roothunter.sh
#  análisis: sugerencias de exploits, attack paths, scoring, diff.
#
#  Uso:
#    rh-analyze reporte.json                    # Análisis estándar
#    rh-analyze reporte.json --score            # Solo score numérico
#    rh-analyze reporte.json --paths            # Solo attack paths
#    rh-analyze reporte.json --exploits         # Solo exploits sugeridos
#    rh-analyze reporte.json --commands         # Comandos exactos sugeridos
#    rh-analyze --diff old.json new.json        # Comparar dos auditorías
#    rh-analyze --batch *.json                  # Priorizar múltiples hosts
#    rh-analyze reporte.json -o analisis.md     # Exportar Markdown
#    rh-analyze --list-techniques               # Coverage de gtfobins+whitelist
#
#  Requiere: Python 3.7+ (solo stdlib)
#  Dependencias opcionales (mismo directorio): gtfobins.py, suid_whitelist.py
#  Solo análisis defensivo. No ejecuta exploits, no automatiza ataque.
# =============================================================================

