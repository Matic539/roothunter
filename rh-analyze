    # ─── 6) Procesos: secretos en /proc/*/environ ────────────────────────
    env_secrets = r.find_by_type('process_env_secret')
    if env_secrets:
        # Solo emitimos UN bloque resumen — el detalle por var queda en el reporte
        # Reliability=5 (el secret está ahí o no), stealth=5 (solo lectura),
