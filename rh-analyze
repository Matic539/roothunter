@exploit(
    cve='CVE-2021-4034',
    name='PwnKit (pkexec)',
    severity='critical',
    description='Manipulación de argv permite escalada a root sin autenticación',
    poc_url='https://github.com/ly4k/PwnKit',
    requires='polkit < 0.120',
)
def _check_pwnkit(r: Report) -> bool:
    # Schema v2: usar el finding dedicado emitido por roothunter v1.1
    if r.is_v2():
        if r.has_type('cve_pwnkit'):
            return True
        # También aceptar la versión cruda si el finding cve_pwnkit no se emitió
        v = _get_pkexec_version(r)
        if v and vlt(v, '0.120'):
            return True
        return False
    # v1: regex
    return r.has(r'pkexec.*<\s*0\.120', r'PwnKit', r'CVE-2021-4034')


