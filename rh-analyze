# ─── ANSI colors ──────────────────────────────────────────────────────────────
class C:
    RED = '\033[0;31m'
    YELLOW = '\033[1;33m'
    GREEN = '\033[0;32m'
    CYAN = '\033[0;36m'
    BOLD = '\033[1m'
    DIM = '\033[2m'
    RESET = '\033[0m'

    @staticmethod
    def disable():
        for attr in dir(C):
            if not attr.startswith('_') and attr.isupper():
                setattr(C, attr, '')


# ─── Modelo de datos ──────────────────────────────────────────────────────────
@dataclass
class Finding:
    """Un hallazgo individual extraído del reporte."""
    severity: str
    module: str
    text: str

    def matches(self, *patterns: str) -> bool:
        """Devuelve True si el texto del hallazgo coincide con cualquier patrón."""
        return any(re.search(p, self.text, re.IGNORECASE) for p in patterns)


@dataclass
class Report:
    """Reporte completo parseado."""
    hostname: str
    kernel: str
    os: str
    user: str
    timestamp: str
    findings: list[Finding] = field(default_factory=list)
    raw: dict = field(default_factory=dict)

    @classmethod
    def from_file(cls, path: Path) -> 'Report':
        with path.open(encoding='utf-8') as f:
            data = json.load(f)
        report = data.get('report', data)
        target = report.get('target', {})
        findings = []
        for module in report.get('modules', []):
            mname = module.get('module', '?')
            for sev in ('critical', 'warnings', 'info'):
                for text in module.get(sev, []):
                    findings.append(Finding(
                        severity=sev.rstrip('s'),  # 'warnings' -> 'warning'
                        module=mname,
                        text=text,
                    ))
        return cls(
            hostname=target.get('hostname', '?'),
            kernel=target.get('kernel', '?'),
            os=target.get('os', '?'),
            user=target.get('user', '?'),
            timestamp=report.get('timestamp', '?'),
            findings=findings,
            raw=report,
        )

    def critical(self) -> list[Finding]:
        return [f for f in self.findings if f.severity == 'critical']

    def warnings(self) -> list[Finding]:
        return [f for f in self.findings if f.severity == 'warning']

    def find(self, *patterns: str) -> list[Finding]:
        """Devuelve todos los findings que coincidan con cualquier patrón."""
        return [f for f in self.findings if f.matches(*patterns)]

    def has(self, *patterns: str) -> bool:
        return bool(self.find(*patterns))


# ─── Comparador de versiones ──────────────────────────────────────────────────
def parse_version(v: str) -> tuple:
    """Convierte '1.8.31p2' en (1, 8, 31) — ignora sufijos no numéricos."""
    m = re.match(r'(\d+(?:\.\d+)*)', v)
    if not m:
        return (0,)
    return tuple(int(x) for x in m.group(1).split('.'))


def vlt(a: str, b: str) -> bool:
    """¿a < b? con padding de zeros."""
    pa, pb = parse_version(a), parse_version(b)
    n = max(len(pa), len(pb))
    pa = pa + (0,) * (n - len(pa))
    pb = pb + (0,) * (n - len(pb))
    return pa < pb


def vge(a: str, b: str) -> bool:
    return not vlt(a, b)


# ─── Base de exploits ─────────────────────────────────────────────────────────
@dataclass
class Exploit:
    cve: str
    name: str
    severity: str           # 'critical' | 'high' | 'medium'
    description: str
    poc_url: str
    # Función predicado: recibe Report y devuelve True si aplica
    applies: callable = None
    requires: str = ''      # Texto explicativo de pre-requisitos

EXPLOITS: list[Exploit] = []


def exploit(cve, name, severity, description, poc_url, requires=''):
    """Decorador para registrar un exploit en la base."""
    def decorator(fn):
        EXPLOITS.append(Exploit(
            cve=cve, name=name, severity=severity,
            description=description, poc_url=poc_url,
            applies=fn, requires=requires,
        ))
        return fn
    return decorator


@exploit(
    cve='CVE-2021-3156',
    name='Baron Samedit (sudo heap overflow)',
    severity='critical',
    description='Heap buffer overflow en sudoedit — escalada local a root',
    poc_url='https://github.com/blasty/CVE-2021-3156',
)
def _check_baron_samedit(r: Report) -> bool:
    # Buscar versión de sudo en los hallazgos
    for f in r.find(r'sudo[:\s]+(\d+\.\d+\.\d+)'):
        m = re.search(r'(\d+\.\d+\.\d+(?:p\d+)?)', f.text)
        if m and vlt(m.group(1), '1.9.5'):
            return True
    return False


@exploit(
    cve='CVE-2021-4034',
    name='PwnKit (pkexec)',
    severity='critical',
    description='Manipulación de argv permite escalada a root sin autenticación',
    poc_url='https://github.com/ly4k/PwnKit',
)
def _check_pwnkit(r: Report) -> bool:
    return r.has(r'pkexec.*<\s*0\.120', r'PwnKit', r'CVE-2021-4034')


@exploit(
    cve='CVE-2022-0847',
    name='Dirty Pipe',
    severity='critical',
    description='Escritura arbitraria en archivos de solo lectura — escalada a root',
    poc_url='https://github.com/AlexisAhmed/CVE-2022-0847-DirtyPipe-Exploits',
)
def _check_dirty_pipe(r: Report) -> bool:
    m = re.match(r'(\d+\.\d+(?:\.\d+)?)', r.kernel)
    if not m:
        return False
    k = m.group(1)
    return vge(k, '5.8') and vlt(k, '5.16.11')


@exploit(
    cve='CVE-2023-4911',
    name='Looney Tunables (glibc)',
    severity='critical',
    description='Buffer overflow en GLIBC_TUNABLES — escalada local',
    poc_url='https://www.qualys.com/2023/10/03/cve-2023-4911/looney-tunables-local-privilege-escalation-glibc-ld-so.txt',
    requires='glibc 2.34 - 2.38',
)
def _check_looney_tunables(r: Report) -> bool:
    for f in r.find(r'glibc[:\s]+(\d+\.\d+)'):
        m = re.search(r'(\d+\.\d+)', f.text)
        if m and vge(m.group(1), '2.34') and vlt(m.group(1), '2.39'):
            return True
    return False


@exploit(
    cve='GTFOBins',
    name='Grupo docker = root en host',
    severity='critical',
    description='Membresía en grupo docker permite montar / del host y obtener root',
    poc_url='https://gtfobins.github.io/gtfobins/docker/',
)
def _check_docker_group(r: Report) -> bool:
