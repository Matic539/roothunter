# ─── Carga del módulo gtfobins (mismo directorio que el script) ──────────────
def _load_gtfobins():
    """Carga gtfobins.py desde el mismo directorio que este script.
    Devuelve None si no se encuentra — la suite sigue funcionando sin la base
    pero sin comandos sugeridos."""
    script_dir = Path(__file__).resolve().parent
    gtf_path = script_dir / 'lib' / 'gtfobins.py'
    if not gtf_path.is_file():
        return None
    try:
        spec = importlib.util.spec_from_file_location('gtfobins', gtf_path)
        mod = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(mod)
        return mod
    except Exception as e:
        print(f"[!] No se pudo cargar gtfobins.py: {e}", file=sys.stderr)
        return None


gtfobins = _load_gtfobins()


def _load_suid_whitelist():
    """Carga suid_whitelist.py desde el mismo directorio. Devuelve None si
    falta — la suite sigue funcionando pero sin filtrado de SUID legítimos."""
    script_dir = Path(__file__).resolve().parent
    p = script_dir / 'lib' / 'suid_whitelist.py'
    if not p.is_file():
        return None
    try:
        spec = importlib.util.spec_from_file_location('suid_whitelist', p)
        mod = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(mod)
        return mod
    except Exception as e:
        print(f"[!] No se pudo cargar suid_whitelist.py: {e}", file=sys.stderr)
        return None


suid_whitelist = _load_suid_whitelist()


def is_suid_legitimate(finding, report) -> tuple[bool, str]:
    """¿Este finding suid_dangerous corresponde a un SUID legítimo de la distro?

    Solo aplica a findings de type='suid_dangerous'. Devuelve (es_legitimo, razon).
    Si la whitelist no está cargada, siempre devuelve (False, '').
    """
    if suid_whitelist is None:
        return False, ''
    if finding.type != 'suid_dangerous':
        return False, ''
    path = finding.data.get('path', '')
    if not path:
        return False, ''
    return suid_whitelist.is_legitimate(path, report.os)

